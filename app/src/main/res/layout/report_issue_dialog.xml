<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="بلاغ عن عطل"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="نوع العطل:"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerIssueType"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/btn_dropdown"
        android:padding="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="رقم المشترك:"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editSubscriberNumber"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="أدخل رقم المشترك"
        android:inputType="phone"
        android:layout_marginBottom="16dp"
        android:padding="8dp"
        android:background="@android:drawable/edit_text" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="وصف العطل (اختياري):"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editDescription"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="اكتب وصفاً مختصراً للعطل..."
        android:inputType="textMultiLine"
        android:gravity="top|start"
        android:layout_marginBottom="8dp"
        android:padding="8dp"
        android:background="@android:drawable/edit_text" />

</LinearLayout>
